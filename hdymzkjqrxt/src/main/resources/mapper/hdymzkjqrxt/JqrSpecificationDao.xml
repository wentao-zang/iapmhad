    <select id="getLi" resultType="com.iapmhad.hdymzkjqrxt.entity.JqrSpecificationEntity">
        SELECT * FROM jqr_specification WHERE id>#{id}
    </select>
    <select id="getLast" resultType="com.iapmhad.hdymzkjqrxt.entity.JqrSpecificationEntity">
        SELECT * FROM jqr_specification  ORDER BY id DESC LIMIT 0,1
    </select>

</mapper>