<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.iapmhad.hdymzkjqrxt.dao.SjclzzSpecificationDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.iapmhad.hdymzkjqrxt.entity.SjclzzSpecificationEntity" id="sjclzzSpecificationMap">
        <result property="id" column="ID"/>
        <result property="deviceId" column="DEVICE_ID"/>
        <result property="deviceCode" column="DEVICE_CODE"/>
        <result property="deviceName" column="DEVICE_NAME"/>
        <result property="cameraCode" column="CAMERA_CODE"/>
        <result property="cameraManufacturer" column="CAMERA_MANUFACTURER"/>
        <result property="measureAccuracyU" column="MEASURE_ACCURACY_U"/>
        <result property="measureAccuracyL" column="MEASURE_ACCURACY_L"/>
        <result property="reposErr" column="REPOS_ERR"/>
        <result property="feedPosErr" column="FEED_POS_ERR"/>
    </resultMap>

    <select id="getLi" resultType="com.iapmhad.hdymzkjqrxt.entity.SjclzzSpecificationEntity">
        SELECT * FROM sjclzz_specification WHERE id>#{id}
    </select>
    <select id="getLast" resultType="com.iapmhad.hdymzkjqrxt.entity.SjclzzSpecificationEntity">
        SELECT * FROM sjclzz_specification  ORDER BY id DESC LIMIT 0,1
    </select>

</mapper>