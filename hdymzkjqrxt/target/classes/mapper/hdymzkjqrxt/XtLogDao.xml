<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.iapmhad.hdymzkjqrxt.dao.XtLogDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.iapmhad.hdymzkjqrxt.entity.XtLogEntity" id="xtLogMap">
        <result property="id" column="ID"/>
        <result property="deviceId" column="DEVICE_ID"/>
        <result property="logTime" column="LOG_TIME"/>
        <result property="operator" column="OPERATOR"/>
        <result property="aircraftId" column="AIRCRAFT_ID"/>
        <result property="task" column="TASK"/>
        <result property="logType" column="LOG_TYPE"/>
        <result property="logContent" column="LOG_CONTENT"/>
    </resultMap>

    <select id="getLi" resultType="com.iapmhad.hdymzkjqrxt.entity.XtLogEntity">
        SELECT * FROM xt_log WHERE id>#{id}
    </select>
    <select id="getLast" resultType="com.iapmhad.hdymzkjqrxt.entity.XtLogEntity">
        SELECT * FROM xt_log  ORDER BY id DESC LIMIT 0,1
    </select>

</mapper>