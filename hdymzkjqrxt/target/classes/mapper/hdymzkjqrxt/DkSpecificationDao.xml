<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.iapmhad.hdymzkjqrxt.dao.DkSpecificationDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.iapmhad.hdymzkjqrxt.entity.DkSpecificationEntity" id="dkSpecificationMap">
        <result property="id" column="ID"/>
        <result property="toolId" column="TOOL_ID"/>
        <result property="toolCode" column="TOOL_CODE"/>
        <result property="storehosePos" column="STOREHOSE_POS"/>
        <result property="toolDiameter" column="TOOL_DIAMETER"/>
        <result property="toolLength" column="TOOL_LENGTH"/>
        <result property="cuttingLength" column="CUTTING_LENGTH"/>
        <result property="noseLength" column="NOSE_LENGTH"/>
        <result property="installLength" column="INSTALL_LENGTH"/>
        <result property="sprialAngel" column="SPRIAL_ANGEL"/>
        <result property="toolTeeth" column="TOOL_TEETH"/>
        <result property="toolType" column="TOOL_TYPE"/>
        <result property="toolMaterial" column="TOOL_MATERIAL"/>
        <result property="manufacturer" column="MANUFACTURER"/>
        <result property="toolLife" column="TOOL_LIFE"/>
        <result property="toolWorktime" column="TOOL_WORKTIME"/>
        <result property="processNum" column="PROCESS_NUM"/>
    </resultMap>

    <select id="getLi" resultType="com.iapmhad.hdymzkjqrxt.entity.DkSpecificationEntity">
        SELECT * FROM dk_specification WHERE id>#{id}
    </select>
    <select id="getLast" resultType="com.iapmhad.hdymzkjqrxt.entity.DkSpecificationEntity">
        SELECT * FROM dk_specification  ORDER BY id DESC LIMIT 0,1
    </select>

</mapper>