<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.iapmhad.member.dao.UserDao">

    <!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.iapmhad.member.entity.UserEntity" id="userMap">
        <result property="userId" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="privilegeId" column="privilege_id"/>
        <result property="gender" column="gender"/>
    </resultMap>
    <select id="verify" resultType="com.iapmhad.member.entity.UserEntity">
        SELECT * FROM USER WHERE username=#{username}
    </select>

<!--    <insert id="saveU">insert into ${tableName} (username,password,privilege_id) values (#{username},#{password},#{privilegeId})</insert>-->
    <select id="saveU" resultType="com.iapmhad.member.entity.UserEntity">
        insert into user (username,password,privilege_id) values (#{username},#{password},#{privilegeId})
    </select>

</mapper>