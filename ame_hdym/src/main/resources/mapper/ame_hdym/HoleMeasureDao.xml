<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.iapmhad.ame_hdym.dao.HoleMeasuretDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.iapmhad.ame_hdym.entity.HoleMeasureEntity" id="holemeasureMap">
        <result property="id" column="ID"/>
        <result property="aircraftId" column="AIRCRAFT_ID"/>
        <result property="flightId" column="FLIGHT_ID"/>
        <result property="productNum" column="PRODUCT_NUM"/>
        <result property="holeId" column="HOLE_ID"/>
        <result property="holeDia" column="hole_dia"/>
        <result property="pitDepth" column="pit_depth"/>
        <result property="time" column="time"/>
    </resultMap>

    <select id="getLi" resultType="com.iapmhad.ame_hdym.entity.HoleMeasureEntity">
        SELECT * FROM hole_measure WHERE id>#{id}
    </select>
    <select id="getHoleMea" resultType="com.iapmhad.ame_hdym.entity.HoleMeasureEntity">
        SELECT * FROM hole_measure  ORDER BY id DESC LIMIT 0,1
    </select>
    <select id="getLast" resultType="com.iapmhad.ame_hdym.entity.HoleMeasureEntity">
        SELECT * FROM hole_measure ORDER BY id DESC LIMIT 0,1
    </select>
    <select id="getChongJi" resultType="com.iapmhad.ame_hdym.entity.HoleMeasureEntity">
        SELECT * FROM hole_measure WHERE `time` > #{strtime};
    </select>
</mapper>